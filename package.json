{
  "name": "run-retro-skill",
  "version": "0.1.0",
  "description": "Summarize agent run logs into decisions, evidence, risks, and next actions.",
  "type": "module",
  "bin": {
    "run-retro-skill": "bin/run-retro-skill.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "node bin/run-retro-skill.js --fixture fixtures/run-log.json",
    "lint": "npm run check",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm run test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "run-audit",
    "retrospective",
    "handoff"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/run-retro-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/run-retro-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/run-retro-skill#readme",
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "examples",
    "scripts",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
